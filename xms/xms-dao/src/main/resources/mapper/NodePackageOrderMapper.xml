<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xms.dao.mapper.NodePackageOrderMapper">

    <resultMap type="NodePackageOrder" id="NodePackageOrderResult">
        <result property="id"    column="id"    />
        <result property="orderNo"    column="order_no"    />
        <result property="userId"    column="user_id"    />
        <result property="address"    column="address"    />
        <result property="hash"    column="hash"    />
        <result property="packageLevel"    column="package_level"    />
        <result property="directReferralRate"    column="direct_referral_rate"    />
        <result property="indirectReferralRate"    column="indirect_referral_rate"    />
        <result property="weightMultiplier"    column="weight_multiplier"    />
        <result property="predOrderFeeReliefRate"    column="pred_order_fee_relief_rate"    />
        <result property="orderValueUsdt"    column="order_value_usdt"    />
        <result property="sourceType"    column="source_type"    />
        <result property="status"    column="status"    />
        <result property="bizStatus"    column="biz_status"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
        <result property="payTime"    column="pay_time"    />
    </resultMap>

    <sql id="selectNodePackageOrderVo">
        select id, order_no, user_id, address, hash, package_level, direct_referral_rate, indirect_referral_rate, weight_multiplier, pred_order_fee_relief_rate, order_value_usdt, source_type, status, biz_status, create_time, update_time, pay_time from t_node_package_order
    </sql>

    <select id="selectNodePackageOrderList" parameterType="NodePackageOrder"
            resultMap="NodePackageOrderResult">
        <include refid="selectNodePackageOrderVo"/>
        <where>
            <if test="orderNo != null  and orderNo != ''"> and order_no = #{orderNo}</if>
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="address != null  and address != ''"> and address = #{address}</if>
            <if test="hash != null  and hash != ''"> and hash = #{hash}</if>
            <if test="packageLevel != null "> and package_level = #{packageLevel}</if>
            <if test="directReferralRate != null "> and direct_referral_rate = #{directReferralRate}</if>
            <if test="indirectReferralRate != null "> and indirect_referral_rate = #{indirectReferralRate}</if>
            <if test="weightMultiplier != null "> and weight_multiplier = #{weightMultiplier}</if>
            <if test="predOrderFeeReliefRate != null "> and pred_order_fee_relief_rate = #{predOrderFeeReliefRate}</if>
            <if test="orderValueUsdt != null "> and order_value_usdt = #{orderValueUsdt}</if>
            <if test="sourceType != null "> and source_type = #{sourceType}</if>
            <if test="status != null "> and status = #{status}</if>
            <if test="bizStatus != null "> and biz_status = #{bizStatus}</if>
            <if test="params.beginCreateTime != null and params.beginCreateTime != '' and params.endCreateTime != null and params.endCreateTime != ''"> and create_time between #{params.beginCreateTime} and #{params.endCreateTime}</if>
            <if test="payTime != null "> and pay_time = #{payTime}</if>
        </where>
        order by id desc
    </select>

</mapper>
