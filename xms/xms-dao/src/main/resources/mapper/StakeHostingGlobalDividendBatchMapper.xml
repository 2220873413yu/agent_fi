<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xms.dao.mapper.StakeHostingGlobalDividendBatchMapper">

    <resultMap type="StakeHostingGlobalDividendBatch" id="StakeHostingGlobalDividendBatchResult">
        <result property="id" column="id" />
        <result property="batchNo" column="batch_no" />
        <result property="settlementDay" column="settlement_day" />
        <result property="periodStartTime" column="period_start_time" />
        <result property="periodEndTime" column="period_end_time" />
        <result property="planAmount" column="plan_amount" />
        <result property="actualAmount" column="actual_amount" />
        <result property="userCount" column="user_count" />
        <result property="status" column="status" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
        <result property="deleted" column="deleted" />
    </resultMap>

    <sql id="selectStakeHostingGlobalDividendBatchVo">
        select id, batch_no, settlement_day, period_start_time, period_end_time, plan_amount,
               actual_amount, user_count, status, create_by, create_time, update_by, update_time,
               remark, deleted
        from t_stake_hosting_global_dividend_batch
    </sql>

    <select id="selectStakeHostingGlobalDividendBatchList" parameterType="StakeHostingGlobalDividendBatch" resultMap="StakeHostingGlobalDividendBatchResult">
        <include refid="selectStakeHostingGlobalDividendBatchVo"/>
        <where>
            <if test="batchNo != null and batchNo != ''"> and batch_no = #{batchNo}</if>
            <if test="settlementDay != null"> and settlement_day = #{settlementDay}</if>
            <if test="status != null"> and status = #{status}</if>
            <if test="params.beginCreateTime != null and params.beginCreateTime != '' and params.endCreateTime != null and params.endCreateTime != ''"> and create_time between #{params.beginCreateTime} and #{params.endCreateTime}</if>
            and deleted = 0
        </where>
        order by id desc
    </select>
</mapper>
