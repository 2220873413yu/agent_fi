    <sql id="selectStakeHostingOrderVo">
        select id, order_no, user_id, account, package_id, package_name, package_days, stake_usdt_amount, service_fee_ratio,
               performance_coefficient, performance_points,
               source_type, pay_status, status, pay_hash, pay_amount, pay_time, effective_time, finish_time,
               run_days, today_reward, total_static_reward, is_return_principal, afi_accelerated, last_reward_day, create_day,
               performance_start_time, performance_end_time, weekly_performance_status, weekly_performance_skip_reason,
               weekly_performance_time, create_by, create_time, update_by, update_time, remark, deleted
        from t_stake_hosting_order
    </sql>

    <sql id="selectStakeHostingOrderDtoVo">
        select o.id, o.order_no, o.user_id, o.account, o.package_id, o.package_name, o.package_days, o.stake_usdt_amount, o.service_fee_ratio,
               o.performance_coefficient, o.performance_points,
               afi.pledge_ratio as afi_pledge_ratio,
               afi.accelerate_rate as afi_accelerate_rate,
               o.source_type, o.pay_status, o.status, o.pay_hash, o.pay_amount, o.pay_time, o.effective_time, o.finish_time,
               o.run_days, o.today_reward, o.total_static_reward, o.is_return_principal, o.afi_accelerated, o.last_reward_day, o.create_day,
               o.performance_start_time, o.performance_end_time, o.weekly_performance_status, o.weekly_performance_skip_reason,
               o.weekly_performance_time, o.create_by, o.create_time, o.update_by, o.update_time, o.remark, o.deleted
        from t_stake_hosting_order o
        left join t_stake_hosting_afi_pledge afi
               on afi.deleted = 0
              and afi.stake_hosting_order_id = o.id
    </sql>

    <select id="selectStakeHostingOrderList" parameterType="StakeHostingOrder" resultMap="StakeHostingOrderResult">
        <include refid="selectStakeHostingOrderVo"/>
        <where>
            <if test="orderNo != null and orderNo != ''"> and order_no = #{orderNo}</if>
            <if test="userId != null"> and user_id = #{userId}</if>
            <if test="account != null and account != ''"> and account = #{account}</if>
            <if test="packageId != null"> and package_id = #{packageId}</if>
            <if test="packageDays != null"> and package_days = #{packageDays}</if>
            <if test="sourceType != null"> and source_type = #{sourceType}</if>
