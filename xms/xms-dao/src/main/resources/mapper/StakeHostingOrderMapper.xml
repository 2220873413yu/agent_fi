            <if test="status != null"> and status = #{status}</if>
            <if test="payHash != null and payHash != ''"> and pay_hash = #{payHash}</if>
            <if test="isReturnPrincipal != null"> and is_return_principal = #{isReturnPrincipal}</if>
            <if test="afiAccelerated != null"> and afi_accelerated = #{afiAccelerated}</if>
            <if test="weeklyPerformanceStatus != null"> and weekly_performance_status = #{weeklyPerformanceStatus}</if>
            <if test="performanceStartTime != null"> and performance_start_time = #{performanceStartTime}</if>
            <if test="params.beginCreateTime != null and params.beginCreateTime != '' and params.endCreateTime != null and params.endCreateTime != ''"> and create_time between #{params.beginCreateTime} and #{params.endCreateTime}</if>
            and deleted = 0
        </where>
        order by id desc
    </select>

