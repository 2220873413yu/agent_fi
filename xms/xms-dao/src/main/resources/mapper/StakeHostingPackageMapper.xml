<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xms.dao.mapper.StakeHostingPackageMapper">

    <resultMap type="StakeHostingPackage" id="StakeHostingPackageResult">
        <result property="id" column="id" />
        <result property="name" column="name" />
        <result property="days" column="days" />
        <result property="minAmount" column="min_amount" />
        <result property="serviceFeeRatio" column="service_fee_ratio" />
        <result property="performanceCoefficient" column="performance_coefficient" />
        <result property="sort" column="sort" />
        <result property="status" column="status" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
        <result property="deleted" column="deleted" />
    </resultMap>

    <sql id="selectStakeHostingPackageVo">
        select id, name, days, min_amount, service_fee_ratio, performance_coefficient, sort, status, create_by, create_time, update_by, update_time, remark, deleted
        from t_stake_hosting_package
    </sql>

    <select id="selectStakeHostingPackageList" parameterType="StakeHostingPackage" resultMap="StakeHostingPackageResult">
        <include refid="selectStakeHostingPackageVo"/>
        <where>
            <if test="name != null and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="days != null"> and days = #{days}</if>
            <if test="status != null"> and status = #{status}</if>
            and deleted = 0
        </where>
        order by sort asc, days asc, id desc
    </select>
</mapper>
