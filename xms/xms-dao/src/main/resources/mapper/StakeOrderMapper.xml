<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xms.dao.mapper.StakeOrderMapper">

    <resultMap type="StakeOrder" id="StakeOrderResult">
        <result property="id"    column="id"    />
        <result property="userId"    column="user_id"    />
        <result property="orderNo"    column="order_no"    />
        <result property="stakeUsdtAmount"    column="stake_usdt_amount"    />
        <result property="status"    column="status"    />
        <result property="remainingOutAmount"    column="remaining_out_amount"    />
        <result property="allOutAmount"    column="all_out_amount"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
        <result property="payTime"    column="pay_time"    />
        <result property="payHash"    column="pay_hash"    />
        <result property="todayReward"    column="today_reward"    />
        <result property="bizStatus1"    column="biz_status1"    />

        <result property="hashFirstShipOrder"    column="hash_first_ship_order"    />
        <result property="shipStatus"    column="ship_status"    />
        <result property="shipTime"    column="ship_time"    />
        <result property="receiverInfo"    column="receiver_info"    />
        <result property="shipCompany"    column="ship_company"    />
        <result property="shipNo"    column="ship_no"    />
        <result property="productSnapshot"    column="product_snapshot"    />
        <result property="num"    column="num"    />
    </resultMap>

    <sql id="selectStakeOrderVo">
        select num, product_snapshot, hash_first_ship_order, ship_status, ship_time, receiver_info, ship_company, ship_no, biz_status1, today_reward, id, user_id, order_no, stake_usdt_amount, status, remaining_out_amount, all_out_amount, create_time, update_time, remark, pay_time, pay_hash from t_stake_order
    </sql>

    <select id="selectStakeOrderList" parameterType="StakeOrder"
            resultMap="StakeOrderResult">
        <include refid="selectStakeOrderVo"/>
        <where>
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="shipNo != null "> and ship_no = #{shipNo}</if>
            <if test="shipCompany != null "> and ship_company = #{shipCompany}</if>
            <if test="shipStatus != null "> and hash_first_ship_order = 1 and ship_status = #{shipStatus}</if>
            <if test="hashFirstShipOrder != null "> and hash_first_ship_order = #{hashFirstShipOrder}</if>

            <if test="bizStatus1 != null "> and biz_status1 = #{bizStatus1}</if>
            <if test="orderNo != null  and orderNo != ''"> and order_no = #{orderNo}</if>
            <if test="stakeUsdtAmount != null "> and stake_usdt_amount = #{stakeUsdtAmount}</if>
            <if test="status != null "> and status = #{status}</if>
            <if test="remainingOutAmount != null "> and remaining_out_amount = #{remainingOutAmount}</if>
            <if test="allOutAmount != null "> and all_out_amount = #{allOutAmount}</if>
            <if test="params.beginCreateTime != null and params.beginCreateTime != '' and params.endCreateTime != null and params.endCreateTime != ''"> and create_time between #{params.beginCreateTime} and #{params.endCreateTime}</if>
            <if test="payTime != null "> and pay_time = #{payTime}</if>
            <if test="payHash != null  and payHash != ''"> and pay_hash = #{payHash}</if>
        </where>
        order by id desc
    </select>

</mapper>
